# =============================================================================
# Remote State Backend (recommended for team/production use)
# =============================================================================
# To enable remote state:
# 1. Create the S3 bucket and DynamoDB table (manually or via a separate config)
# 2. Rename this file to backend.tf
# 3. Run: terraform init -migrate-state
#
# terraform {
#   backend "s3" {
#     bucket         = "your-terraform-state-bucket"
#     key            = "aws-vpn-lab/terraform.tfstate"
#     region         = "us-east-1"
#     encrypt        = true
#     dynamodb_table = "terraform-state-locks"
#   }
# }
