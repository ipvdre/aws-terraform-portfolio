# Terraform state files - contain plaintext secrets
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files - contain sensitive values
terraform.tfvars
*.tfvars
!*.tfvars.example

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# SSH keys
*.pem
*.key
id_rsa
id_rsa.pub
*.pub

# AWS credentials
.aws/
credentials

# Environment files
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo